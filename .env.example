# Local LLM (OpenAI-compatible endpoint, e.g. llama-server)
MEM0_LLM_PROVIDER=openai
MEM0_LLM_BASE_URL=http://localhost:8080/v1
MEM0_LLM_MODEL=local-model
MEM0_LLM_API_KEY=not-needed
MEM0_LLM_TEMPERATURE=0.1
MEM0_LLM_MAX_TOKENS=2000

# Embedder (HuggingFace SentenceTransformers, runs on CPU)
MEM0_EMBEDDER_PROVIDER=huggingface
MEM0_EMBEDDER_MODEL=multi-qa-MiniLM-L6-cos-v1
MEM0_EMBEDDING_DIMS=384

# Vector store (Qdrant file mode, no server needed)
MEM0_VECTOR_STORE=qdrant
MEM0_COLLECTION=mem0
MEM0_QDRANT_PATH=~/.local/share/mem0/qdrant

# Data directory (history DB and vector store default location)
MEM0_DATA_DIR=~/.local/share/mem0

# Default user ID for scoping memories
MEM0_DEFAULT_USER_ID=default

# Disable telemetry
MEM0_TELEMETRY=false
